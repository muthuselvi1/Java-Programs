public class Solution {
    public int reverse(int x) {
        int result = 0; // This will hold the reversed number
        while (x != 0) {
            int digit = x % 10; // Get the last digit
            x /= 10; // Remove the last digit from x

            // Check for overflow before actually adding the new digit
            if (result > Integer.MAX_VALUE / 10 || (result == Integer.MAX_VALUE / 10 && digit > 7)) {
                return 0; // Overflow condition for positive numbers
            }
            if (result < Integer.MIN_VALUE / 10 || (result == Integer.MIN_VALUE / 10 && digit < -8)) {
                return 0; // Overflow condition for negative numbers
            }

            result = result * 10 + digit; // Append the digit to the result
        }
        return result; // Return the reversed integer
    }
}


           
            
